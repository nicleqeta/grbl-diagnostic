{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gcomposer.app/schemas/controller-profiles.schema.json",
  "title": "GCOM Controller Profile Registry",
  "description": "Strict profile registry for controller flavor aware GCOM/GCode generation with an optional v2 preview block for higher-level compiler planning.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "default_profile_id",
    "profiles"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "registry_id": {
      "type": "string",
      "const": "gcomposer-controller-profiles"
    },
    "default_profile_id": {
      "type": "string",
      "enum": [
        "grbl-vanilla",
        "fluidnc"
      ]
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grbl-base",
        "grbl-vanilla",
        "fluidnc"
      ],
      "properties": {
        "grbl-base": {
          "$ref": "#/$defs/grblBaseProfile"
        },
        "grbl-vanilla": {
          "$ref": "#/$defs/grblVanillaProfile"
        },
        "fluidnc": {
          "$ref": "#/$defs/fluidNcProfile"
        }
      }
    },
    "v2_preview": {
      "$ref": "#/$defs/v2Preview"
    }
  },
  "$defs": {
    "regexPattern": {
      "type": "string",
      "minLength": 1
    },
    "aiGuidance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "preferred_style",
        "avoid",
        "compatibility_policy"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "preferred_style": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "avoid": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "compatibility_policy": {
          "type": "string",
          "enum": [
            "allow_warn_block"
          ]
        }
      }
    },
    "boilerplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "gcom"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "gcom": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "supports_usb_serial",
        "supports_websocket"
      ],
      "properties": {
        "primary": {
          "type": "string",
          "enum": [
            "serial-ascii"
          ]
        },
        "supports_usb_serial": {
          "type": "boolean"
        },
        "supports_websocket": {
          "type": "boolean"
        }
      }
    },
    "ackPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "default_timeout_ms",
        "ok_regex",
        "error_regex",
        "alarm_regex"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "required",
            "optional",
            "none"
          ]
        },
        "default_timeout_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 60000
        },
        "ok_regex": {
          "$ref": "#/$defs/regexPattern"
        },
        "error_regex": {
          "$ref": "#/$defs/regexPattern"
        },
        "alarm_regex": {
          "$ref": "#/$defs/regexPattern"
        }
      }
    },
    "realtimeCommands": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "feed_hold",
        "cycle_start",
        "soft_reset"
      ],
      "properties": {
        "status": {
          "type": "string",
          "const": "?"
        },
        "feed_hold": {
          "type": "string",
          "const": "!"
        },
        "cycle_start": {
          "type": "string",
          "const": "~"
        },
        "soft_reset": {
          "type": "string",
          "pattern": "^(\\^X|\\\\x18)$"
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gcode_core",
        "grbl_system",
        "realtime",
        "notes"
      ],
      "properties": {
        "gcode_core": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[GMT$][A-Z0-9.]*$"
          }
        },
        "grbl_system": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^\\$[A-Z0-9#/.*=]+$"
          }
        },
        "realtime": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(\\?|!|~|\\^X|0x[0-9A-Fa-f]{2})$"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "compatibilityRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "match",
        "decision",
        "reason_code",
        "message"
      ],
      "properties": {
        "match": {
          "$ref": "#/$defs/regexPattern"
        },
        "decision": {
          "type": "string",
          "enum": [
            "allow",
            "warn",
            "block"
          ]
        },
        "reason_code": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "profileCommon": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "controller_family",
        "status",
        "inherits",
        "transport",
        "ack_policy",
        "response_patterns",
        "realtime_commands",
        "capabilities",
        "compatibility_rules",
        "boilerplate",
        "ai_guidance"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "controller_family": {
          "type": "string",
          "enum": [
            "grbl"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "stable",
            "experimental",
            "planned"
          ]
        },
        "inherits": {
          "type": [
            "string",
            "null"
          ]
        },
        "transport": {
          "$ref": "#/$defs/transport"
        },
        "ack_policy": {
          "$ref": "#/$defs/ackPolicy"
        },
        "response_patterns": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "startup_banner_regex",
            "status_report_regex",
            "message_prefixes"
          ],
          "properties": {
            "startup_banner_regex": {
              "$ref": "#/$defs/regexPattern"
            },
            "status_report_regex": {
              "$ref": "#/$defs/regexPattern"
            },
            "message_prefixes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "realtime_commands": {
          "$ref": "#/$defs/realtimeCommands"
        },
        "capabilities": {
          "$ref": "#/$defs/capabilities"
        },
        "compatibility_rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/compatibilityRule"
          }
        },
        "boilerplate": {
          "$ref": "#/$defs/boilerplate"
        },
        "ai_guidance": {
          "$ref": "#/$defs/aiGuidance"
        }
      }
    },
    "grblBaseProfile": {
      "allOf": [
        {
          "$ref": "#/$defs/profileCommon"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "grbl-base"
            },
            "label": {
              "const": "GRBL Base"
            },
            "status": {
              "const": "stable"
            },
            "inherits": {
              "type": "null"
            }
          }
        }
      ]
    },
    "grblVanillaProfile": {
      "allOf": [
        {
          "$ref": "#/$defs/profileCommon"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "grbl-vanilla"
            },
            "label": {
              "const": "Vanilla GRBL"
            },
            "status": {
              "const": "stable"
            },
            "inherits": {
              "const": "grbl-base"
            }
          }
        }
      ]
    },
    "fluidNcProfile": {
      "allOf": [
        {
          "$ref": "#/$defs/profileCommon"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "fluidnc"
            },
            "label": {
              "const": "FluidNC"
            },
            "status": {
              "const": "stable"
            },
            "inherits": {
              "const": "grbl-base"
            }
          }
        }
      ]
    },
    "v2Preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "default_base_profile_id",
        "base_profiles"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "2.0.0"
        },
        "default_base_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "base_profiles": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/baseProfileV2"
          }
        }
      }
    },
    "baseProfileV2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "family",
        "status",
        "inherits",
        "runtime",
        "compile",
        "guidance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "stable",
            "experimental",
            "planned"
          ]
        },
        "inherits": {
          "type": [
            "string",
            "null"
          ]
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ack_policy",
            "startup_banner_regex",
            "status_report_regex"
          ],
          "properties": {
            "ack_policy": {
              "$ref": "#/$defs/ackPolicy"
            },
            "startup_banner_regex": {
              "$ref": "#/$defs/regexPattern"
            },
            "status_report_regex": {
              "$ref": "#/$defs/regexPattern"
            }
          }
        },
        "compile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "modal_reset",
            "abstract_ops",
            "machine_model",
            "state_map"
          ],
          "properties": {
            "modal_reset": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "units",
                "distance",
                "feed_mode",
                "plane",
                "motion",
                "wcs"
              ],
              "properties": {
                "units": {
                  "type": "string",
                  "minLength": 1
                },
                "distance": {
                  "type": "string",
                  "minLength": 1
                },
                "feed_mode": {
                  "type": "string",
                  "minLength": 1
                },
                "plane": {
                  "type": "string",
                  "minLength": 1
                },
                "motion": {
                  "type": "string",
                  "minLength": 1
                },
                "wcs": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "abstract_ops": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "command",
                      "gcode",
                      "sequence",
                      "realtime",
                      "unsupported"
                    ]
                  },
                  "emit": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "wait": {
                    "type": "string"
                  }
                }
              }
            },
            "machine_model": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "supports_homing",
                "supports_machine_coordinates",
                "supports_tool_table",
                "supports_macro_call",
                "supports_canned_cycles",
                "supports_multiple_spindles"
              ],
              "properties": {
                "supports_homing": {
                  "type": "boolean"
                },
                "supports_machine_coordinates": {
                  "type": "boolean"
                },
                "supports_tool_table": {
                  "type": "boolean"
                },
                "supports_macro_call": {
                  "type": "boolean"
                },
                "supports_canned_cycles": {
                  "type": "boolean"
                },
                "supports_multiple_spindles": {
                  "type": "boolean"
                }
              }
            },
            "state_map": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "idle",
                "run",
                "hold",
                "alarm"
              ],
              "properties": {
                "idle": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "run": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "hold": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "alarm": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "home": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "guidance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "summary",
            "preferred_style",
            "avoid"
          ],
          "properties": {
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "preferred_style": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "avoid": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
