{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gcomposer.app/schemas/controller-profiles.schema.json",
  "title": "GCOM Controller Profile Registry",
  "description": "Standalone controller profiles for compile-time lowering of abstract keywords into concrete GCOM.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "default_profile_id",
    "profiles"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "registry_id": {
      "type": "string",
      "const": "gcomposer-controller-profiles"
    },
    "default_profile_id": {
      "type": "string",
      "enum": [
        "grbl-vanilla",
        "fluidnc"
      ]
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grbl-vanilla",
        "fluidnc"
      ],
      "properties": {
        "grbl-vanilla": {
          "$ref": "#/$defs/standaloneProfile"
        },
        "fluidnc": {
          "$ref": "#/$defs/standaloneProfile"
        }
      }
    }
  },
  "$defs": {
    "regexPattern": {
      "type": "string",
      "minLength": 1
    },
    "aiGuidance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "preferred_style",
        "avoid",
        "compatibility_policy"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "preferred_style": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "avoid": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "compatibility_policy": {
          "type": "string",
          "enum": [
            "allow_warn_block"
          ]
        }
      }
    },
    "boilerplateGcom": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "gcom"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "gcom": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ackPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "default_timeout_ms",
        "ok_regex",
        "error_regex",
        "alarm_regex"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "required",
            "optional",
            "none"
          ]
        },
        "default_timeout_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 60000
        },
        "ok_regex": {
          "$ref": "#/$defs/regexPattern"
        },
        "error_regex": {
          "$ref": "#/$defs/regexPattern"
        },
        "alarm_regex": {
          "$ref": "#/$defs/regexPattern"
        }
      }
    },
    "connectionDefaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_transport",
        "baud_rate",
        "supports_usb_serial",
        "supports_websocket"
      ],
      "properties": {
        "primary_transport": {
          "type": "string",
          "enum": [
            "serial-ascii"
          ]
        },
        "baud_rate": {
          "type": "integer",
          "minimum": 300
        },
        "supports_usb_serial": {
          "type": "boolean"
        },
        "supports_websocket": {
          "type": "boolean"
        }
      }
    },
    "capabilityFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supports_homing",
        "supports_machine_coordinates",
        "supports_tool_table",
        "supports_macro_call",
        "supports_canned_cycles",
        "supports_multiple_spindles"
      ],
      "properties": {
        "supports_homing": {
          "type": "boolean"
        },
        "supports_machine_coordinates": {
          "type": "boolean"
        },
        "supports_tool_table": {
          "type": "boolean"
        },
        "supports_macro_call": {
          "type": "boolean"
        },
        "supports_canned_cycles": {
          "type": "boolean"
        },
        "supports_multiple_spindles": {
          "type": "boolean"
        }
      }
    },
    "machineDescription": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "controller_family",
        "status",
        "axes",
        "capability_flags",
        "ack_policy",
        "connection_defaults",
        "ai_guidance",
        "boilerplate_gcom"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "grbl-vanilla",
            "fluidnc"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "controller_family": {
          "type": "string",
          "enum": [
            "grbl"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "stable",
            "experimental",
            "planned"
          ]
        },
        "axes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Z]$"
          }
        },
        "capability_flags": {
          "$ref": "#/$defs/capabilityFlags"
        },
        "ack_policy": {
          "$ref": "#/$defs/ackPolicy"
        },
        "connection_defaults": {
          "$ref": "#/$defs/connectionDefaults"
        },
        "ai_guidance": {
          "$ref": "#/$defs/aiGuidance"
        },
        "boilerplate_gcom": {
          "$ref": "#/$defs/boilerplateGcom"
        }
      }
    },
    "featureGuardWarning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message"
      ],
      "properties": {
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ruleParameterBounds": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          }
        }
      }
    },
    "ruleDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "emit": {
          "type": "string",
          "minLength": 1
        },
        "unsupported": {
          "type": "boolean"
        },
        "args": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "number",
                  "string",
                  "boolean"
                ]
              },
              "required": {
                "type": "boolean"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "params": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "number",
                  "string",
                  "boolean"
                ]
              },
              "required": {
                "type": "boolean"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "parameter_bounds": {
          "$ref": "#/$defs/ruleParameterBounds"
        },
        "feature_guard_warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featureGuardWarning"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "emit"
          ]
        },
        {
          "required": [
            "unsupported"
          ],
          "properties": {
            "unsupported": {
              "const": true
            }
          }
        }
      ]
    },
    "operationVariableDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "default"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "default": {
          "oneOf": [
            { "type": "number" },
            { "type": "string" },
            { "type": "boolean" }
          ]
        }
      }
    },
    "operationVariables": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/operationVariableDefinition"
      }
    },
    "operationDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template"
      ],
      "properties": {
        "template": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "operations": {
      "type": "object",
      "properties": {
        "variables": {
          "$ref": "#/$defs/operationVariables"
        }
      },
      "patternProperties": {
        "^(?!variables$).+": {
          "$ref": "#/$defs/operationDefinition"
        }
      },
      "propertyNames": {
        "not": {
          "enum": [
            "HOME",
            "STATUS",
            "RESET",
            "SPINDLE_ON",
            "PROBE"
          ]
        }
      },
      "additionalProperties": false
    },
    "ruleSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "HOME",
        "STATUS",
        "RESET",
        "SPINDLE_ON",
        "PROBE"
      ],
      "properties": {
        "HOME": {
          "$ref": "#/$defs/ruleDefinition"
        },
        "STATUS": {
          "$ref": "#/$defs/ruleDefinition"
        },
        "RESET": {
          "$ref": "#/$defs/ruleDefinition"
        },
        "SPINDLE_ON": {
          "$ref": "#/$defs/ruleDefinition"
        },
        "PROBE": {
          "$ref": "#/$defs/ruleDefinition"
        }
      }
    },
    "compilerStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "grbl-1.1",
            "fluidnc"
          ]
        }
      }
    },
    "standaloneProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "machine_description",
        "rule_set",
        "compiler_strategy"
      ],
      "properties": {
        "machine_description": {
          "$ref": "#/$defs/machineDescription"
        },
        "rule_set": {
          "$ref": "#/$defs/ruleSet"
        },
        "operations": {
          "$ref": "#/$defs/operations"
        },
        "compiler_strategy": {
          "$ref": "#/$defs/compilerStrategy"
        }
      }
    }
  }
}
