        "supports_websocket": true
      },
      "ack_policy": {
        "mode": "required",
        "default_timeout_ms": 3500,
        "ok_regex": "^ok$",
        "error_regex": "^error:(\\d+)$",
        "alarm_regex": "^ALARM:(\\d+)$"
      },
      "response_patterns": {
        "startup_banner_regex": "^Grbl\\s+1\\.1[h-gde]",
        "status_report_regex": "^<[^>]+>$",
        "message_prefixes": [
          "ok",
          "error:",
          "ALARM:",
          "[MSG:",
          "[GC:",
          "[VER:"
        ]
      },
      "realtime_commands": {
        "status": "?",
        "feed_hold": "!",
        "cycle_start": "~",
        "soft_reset": "^X"
      },
      "capabilities": {
        "gcode_core": [
          "G0",
