          "0x9E",
          "0xA0",
          "0xA1"
        ],
        "notes": [
          "FluidNC maintains broad GRBL sender compatibility.",
          "Settings are often managed via config file semantics rather than only legacy $ settings."
        ]
      },
      "compatibility_rules": [
        {
          "match": "^\\$Config/Filename=",
          "decision": "allow",
          "reason_code": "FLUIDNC_CONFIG_FILENAME",
          "message": "FluidNC config filename command is supported."
        },
        {
          "match": "^\\$SLP\\b",
          "decision": "warn",
          "reason_code": "SLEEP_BEHAVIOR_MAY_DIFFER",
          "message": "Sleep behavior can differ by build and machine config."
        },
        {
          "match": "^G41|^G42",
          "decision": "block",
          "reason_code": "CUTTER_COMP_UNSUPPORTED",
          "message": "Cutter compensation G41/G42 should be treated as unsupported in this profile."
        }
      ],
      "boilerplate": {
        "title": "FluidNC Starter",
        "description": "Fast sanity sequence for FluidNC with GRBL-compatible sender flow.",
        "gcom": "10 PRINT \"FluidNC starter\"\n20 SEND \"$I\" WAIT FOR OK\n30 SEND \"$G\" WAIT FOR OK\n40 SEND \"?\"\n50 SEND \"$Config/Filename=config.yaml\" WAIT FOR OK\n60 END"
      },
      "ai_guidance": {
        "summary": "Use GRBL-compatible command flow first, then FluidNC-specific commands when explicitly useful.",
        "preferred_style": [
          "Start from GRBL-safe command forms.",
          "Use FluidNC config commands only when profile-specific configuration is intended.",
          "Annotate any profile-specific command in generated explanations."
        ],
        "avoid": [
          "Do not assume every machine exposes identical FluidNC extensions.",
          "Do not replace standard GRBL flow with config commands unless requested.",
          "Do not silently downgrade blocked commands."
        ],
        "compatibility_policy": "allow_warn_block"
      }
    }
