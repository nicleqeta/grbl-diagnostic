          "0x9B",
          "0x9C",
          "0x9D",
          "0x9E",
          "0xA0",
          "0xA1"
        ],
        "notes": [
          "Tuned for gnea/grbl 1.1 sender protocol.",
          "Treat unknown system command extensions as warn, not block, unless safety-critical."
        ]
      },
      "compatibility_rules": [
        {
          "match": "^\\$J=",
          "decision": "allow",
          "reason_code": "JOG_SUPPORTED",
          "message": "Realtime jogging command is supported in GRBL 1.1."
        },
        {
          "match": "^\\$Config/",
          "decision": "block",
          "reason_code": "FLUIDNC_ONLY_COMMAND",
          "message": "FluidNC config command is not part of vanilla GRBL."
        },
        {
          "match": "^M7\\b",
          "decision": "warn",
          "reason_code": "M7_BUILD_OPTIONAL",
          "message": "M7 requires compile-time option ENABLE_M7 on many GRBL builds."
        }
      ],
      "boilerplate": {
        "title": "Vanilla GRBL Starter",
        "description": "Minimal setup sequence for common GRBL 1.1 machines.",
        "gcom": "10 PRINT \"Vanilla GRBL starter\"\n20 SEND \"$I\" WAIT FOR OK\n30 SEND \"$G\" WAIT FOR OK\n40 SEND \"G90\" WAIT FOR OK\n50 SEND \"G21\" WAIT FOR OK\n60 SEND \"?\"\n70 END"
      },
      "ai_guidance": {
        "summary": "Assume strict GRBL 1.1 behavior and prefer broadly supported command forms.",
        "preferred_style": [
          "Initialize parser state explicitly with G90 and unit mode.",
          "Use conservative modal transitions and explicit feed rates.",
          "Wrap setup commands with WAIT FOR OK."
        ],
        "avoid": [
          "Do not emit FluidNC-specific config commands.",
          "Do not assume macro or canned cycle support.",
          "Do not emit advanced M-codes unless explicitly requested."
        ],
        "compatibility_policy": "allow_warn_block"
      }
    },
    "fluidnc": {
      "id": "fluidnc",
      "label": "FluidNC",
      "controller_family": "grbl",
      "status": "stable",
      "inherits": "grbl-base",
      "transport": {
        "primary": "serial-ascii",
        "supports_usb_serial": true,
        "supports_websocket": true
