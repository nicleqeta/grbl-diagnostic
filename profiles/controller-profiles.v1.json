{
  "$schema": "./controller-profiles.schema.json",
  "schema_version": "1.0.0",
  "registry_id": "gcomposer-controller-profiles",
  "default_profile_id": "grbl-vanilla",
  "profiles": {
    "grbl-vanilla": {
      "machine_description": {
        "id": "grbl-vanilla",
        "label": "Vanilla GRBL",
        "controller_family": "grbl",
        "status": "stable",
        "axes": [
          "X",
          "Y",
          "Z"
        ],
        "max_feed_rate": 6000,
        "arc_support": true,
        "capability_flags": {
          "supports_homing": true,
          "supports_machine_coordinates": true,
          "supports_tool_table": false,
          "supports_macro_call": false,
          "supports_canned_cycles": false,
          "supports_multiple_spindles": false
        },
        "ack_policy": {
          "mode": "required",
          "default_timeout_ms": 3500,
          "ok_regex": "^ok$",
          "error_regex": "^error:(\\d+)$",
          "alarm_regex": "^ALARM:(\\d+)$"
        },
        "connection_defaults": {
          "primary_transport": "serial-ascii",
          "baud_rate": 115200,
          "supports_usb_serial": true,
          "supports_websocket": true
        },
        "ai_guidance": {
          "summary": "Assume strict GRBL 1.1 behavior and prefer broadly supported command forms.",
          "preferred_style": [
            "Initialize parser state explicitly with G90 and unit mode.",
            "Use conservative modal transitions and explicit feed rates.",
            "Wrap setup commands with REQUIRE_OK on SEND."
          ],
          "avoid": [
            "Do not emit FluidNC-specific config commands.",
            "Do not assume macro or canned cycle support.",
            "Do not emit advanced M-codes unless explicitly requested."
          ],
          "compatibility_policy": "allow_warn_block"
        },
        "boilerplate_gcom": {
          "title": "Vanilla GRBL Starter",
          "description": "Minimal setup sequence for common GRBL 1.1 machines.",
          "gcom": "10 PRINT \"Vanilla GRBL starter\"\n20 SEND \"$I\" REQUIRE_OK\n30 SEND \"$G\" REQUIRE_OK\n40 SEND \"G90\" REQUIRE_OK\n50 SEND \"G21\" REQUIRE_OK\n60 STATUS\n70 END"
        }
      },
      "rule_set": {
        "HOME": {
          "emit": "SEND \"$H\" REQUIRE_OK",
          "parameter_bounds": {},
          "feature_guard_warnings": []
        },
        "STATUS": {
          "emit": "STATUS",
          "parameter_bounds": {},
          "feature_guard_warnings": []
        },
        "RESET": {
          "emit": "SOFT_RESET",
          "parameter_bounds": {},
          "feature_guard_warnings": []
        },
        "SPINDLE_ON": {
          "emit": "SEND \"M3 S{power}\" REQUIRE_OK",
          "parameter_bounds": {
            "power": {
              "min": 0,
              "max": 10000
            }
          },
          "feature_guard_warnings": []
        },
        "PROBE": {
          "unsupported": true,
          "parameter_bounds": {},
          "feature_guard_warnings": [
            {
              "message": "PROBE is not enabled for grbl-vanilla in this phase."
            }
          ]
        }
      },
      "operations": {
        "variables": {
          "x": {
            "description": "Target X position",
            "default": 0
          },
          "y": {
            "description": "Target Y position",
            "default": 0
          },
          "z": {
            "description": "Target Z position",
            "default": 0
          },
          "speed": {
            "label": "Feed rate (mm/min)",
            "description": "Feed rate",
            "default": 1000
          },
          "spindlespeed": {
            "label": "Laser power (0–1000)",
            "description": "Spindle/laser power",
            "default": 1000
          },
          "dwell": {
            "label": "Dwell time (seconds)",
            "description": "Dwell time (seconds)",
            "default": 1
          }
        },
        "cut_move": {
          "template": [
            "SEND \"G1 [X]{x}[Y]{y}[Z]{z}[F]{speed}\" REQUIRE_OK"
          ]
        },
        "rapid_move": {
          "template": [
            "SEND \"G0 [X]{x}[Y]{y}[Z]{z}\" REQUIRE_OK"
          ]
        },
        "tool_on": {
          "template": [
            "SEND \"M3 S{spindlespeed}\" REQUIRE_OK"
          ]
        },
        "tool_off": {
          "template": [
            "SEND \"M5\" REQUIRE_OK"
          ]
        },
        "dwell": {
          "template": [
            "SEND \"G4 P{dwell}\" REQUIRE_OK"
          ]
        },
        "zero_all_axes": {
          "template": [
            "SEND \"G10 L20 P1 X0Y0Z0\" REQUIRE_OK"
          ]
        },
        "job_end": {
          "template": [
            "SEND \"M2\" REQUIRE_OK"
          ]
        }
      },
      "compiler_strategy": {
        "name": "grbl-1.1"
      }
    },
    "fluidnc": {
      "machine_description": {
        "id": "fluidnc",
        "label": "FluidNC",
        "controller_family": "grbl",
        "status": "stable",
        "axes": [
          "X",
          "Y",
          "Z"
        ],
        "max_feed_rate": 10000,
        "arc_support": true,
        "capability_flags": {
          "supports_homing": true,
          "supports_machine_coordinates": true,
          "supports_tool_table": false,
          "supports_macro_call": false,
          "supports_canned_cycles": false,
          "supports_multiple_spindles": true
        },
        "ack_policy": {
          "mode": "required",
          "default_timeout_ms": 4000,
          "ok_regex": "^ok$",
          "error_regex": "^error:(\\d+|.*)$",
          "alarm_regex": "^ALARM:(\\d+|.*)$"
        },
        "connection_defaults": {
          "primary_transport": "serial-ascii",
          "baud_rate": 115200,
          "supports_usb_serial": true,
          "supports_websocket": true
        },
        "ai_guidance": {
          "summary": "Use GRBL-compatible command flow first, then FluidNC-specific commands when explicitly useful.",
          "preferred_style": [
            "Start from GRBL-safe command forms.",
            "Use FluidNC config commands only when profile-specific configuration is intended.",
            "Annotate any profile-specific command in generated explanations."
          ],
          "avoid": [
            "Do not assume every machine exposes identical FluidNC extensions.",
            "Do not replace standard GRBL flow with config commands unless requested.",
            "Do not silently downgrade blocked commands."
          ],
          "compatibility_policy": "allow_warn_block"
        },
        "boilerplate_gcom": {
          "title": "FluidNC Starter",
          "description": "Fast sanity sequence for FluidNC with GRBL-compatible sender flow.",
          "gcom": "10 PRINT \"FluidNC starter\"\n20 SEND \"$I\" REQUIRE_OK\n30 SEND \"$G\" REQUIRE_OK\n40 STATUS\n50 SEND \"$Config/Filename=config.yaml\" REQUIRE_OK\n60 END"
        }
      },
      "rule_set": {
        "HOME": {
          "emit": "SEND \"$H\" TIMEOUT 4000 REQUIRE_OK",
          "parameter_bounds": {},
          "feature_guard_warnings": [
            {
              "message": "FluidNC homing behavior can vary by machine configuration; keep idle-state verification in the calling flow if needed."
            }
          ]
        },
        "STATUS": {
          "emit": "STATUS",
          "parameter_bounds": {},
          "feature_guard_warnings": []
        },
        "RESET": {
          "emit": "SOFT_RESET",
          "parameter_bounds": {},
          "feature_guard_warnings": []
        },
        "SPINDLE_ON": {
          "emit": "SEND \"M3 S{power}\" REQUIRE_OK",
          "parameter_bounds": {
            "power": {
              "min": 0,
              "max": 10000
            }
          },
          "feature_guard_warnings": []
        },
        "PROBE": {
          "emit": "SEND \"G38.2 Z-5 F100\" REQUIRE_OK",
          "parameter_bounds": {},
          "feature_guard_warnings": []
        }
      },
      "operations": {
        "variables": {
          "x": {
            "description": "Target X position",
            "default": 0
          },
          "y": {
            "description": "Target Y position",
            "default": 0
          },
          "z": {
            "description": "Target Z position",
            "default": 0
          },
          "speed": {
            "label": "Feed rate (mm/min)",
            "description": "Feed rate",
            "default": 1000
          },
          "spindlespeed": {
            "label": "Laser power (0–1000)",
            "description": "Spindle/laser power",
            "default": 1000
          },
          "dwell": {
            "label": "Dwell time (seconds)",
            "description": "Dwell time (seconds)",
            "default": 1
          }
        },
        "cut_move": {
          "template": [
            "SEND \"G1 [X]{x}[Y]{y}[Z]{z}[F]{speed}\" REQUIRE_OK"
          ]
        },
        "rapid_move": {
          "template": [
            "SEND \"G0 [X]{x}[Y]{y}[Z]{z}\" REQUIRE_OK"
          ]
        },
        "tool_on": {
          "template": [
            "SEND \"M3 S{spindlespeed}\" REQUIRE_OK"
          ]
        },
        "tool_off": {
          "template": [
            "SEND \"M5\" REQUIRE_OK"
          ]
        },
        "dwell": {
          "template": [
            "SEND \"G4 P{dwell}\" REQUIRE_OK"
          ]
        },
        "zero_all_axes": {
          "template": [
            "SEND \"G10 L20 P1 X0Y0Z0\" REQUIRE_OK"
          ]
        },
        "job_end": {
          "template": [
            "SEND \"M2\" REQUIRE_OK"
          ]
        }
      },
      "compiler_strategy": {
        "name": "fluidnc"
      }
    }
  }
}
