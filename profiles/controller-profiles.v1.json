        ],
        "grbl_system": [
          "$$",
          "$#",
          "$G",
          "$I",
          "$N",
          "$X",
          "$H",
          "$C",
          "$SLP",
          "$RST=$",
          "$RST=#",
          "$RST=*",
          "$J=..."
        ],
        "realtime": [
          "?",
          "!",
          "~",
          "^X",
          "0x85",
          "0x84",
          "0x90",
          "0x91",
